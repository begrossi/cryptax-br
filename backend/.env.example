DATABASE_URL=sqlite+aiosqlite:///./cryptax.db
SECRET_KEY=change-me-to-a-random-32-char-string
COINGECKO_API_KEY=
# Free API key from https://etherscan.io/apis — required for EVM on-chain sync
# Without it, Etherscan rate-limits heavily and syncs will fail
ETHERSCAN_API_KEY=
# Shared secret required on every API request (header X-API-Token). The frontend
# proxy sends it automatically. Generate one: openssl rand -hex 32
# Leave empty ONLY for local single-user dev — the backend is then fully open.
API_TOKEN=
DEBUG=false
